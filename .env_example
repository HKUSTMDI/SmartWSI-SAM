SAM_CHOICE=SAM2
SERVER_PORT=9091

# 使用相对路径，本地与容器（WORKDIR=/app）通用
SAM2_CHECKPOINT=./models/sam2_hiera_base_plus.pt
SAM2_CONFIG=sam2_hiera_b+.yaml

SDPC_TILE_PREFIX=
SDPC_TILE_IMAGEURL=
SVS_TILE_PREFIX=
SVS_TILE_IMAGEURL=
LOCAL_TILE_URL=./tiles
DOWNLOAD_RETRY=3
LOCAL_STORAGE=/home/mdi/.cache/label-studio/
TEST_TILE_STORAGE=./tile_image/

# 注意：docker --env-file 不支持引号和行尾注释
# 所有值必须直接写成 KEY=VALUE，注释只能独占一行

# 缓存文件最长保留时间（小时），超过则被清理
CACHE_MAX_AGE_HOURS=24
# 后台清理任务执行间隔（小时）
CACHE_CLEAN_INTERVAL_HOURS=1

# Gunicorn 进程数，通常保持 1（多进程会各自独立加载模型，多占显存）
GUNICORN_WORKERS=1
# 每进程线程数，用于并发处理 I/O（图片下载/WSI 拼接），不额外占显存
GUNICORN_THREADS=4
# 请求超时秒数，WSI 推理耗时较长建议 ≥120
GUNICORN_TIMEOUT=120

# 模型实例池大小：
#   单 GPU：设为 GPU 可容纳的副本数（SAM2-base+ 约 2-4 GB/实例）
#   多 GPU：设为 GPU 数量，每个 GPU 分配一个实例，真正并行推理
PREDICTOR_POOL_SIZE=1
